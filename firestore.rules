rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isEditor() {
       return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'editor');
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Rules
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && 
                      incoming().role == 'user' && 
                      incoming().createdAt == request.time;
      allow update: if isOwner(userId) && 
                      incoming().role == existing().role && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'profileImage', 'location', 'lastLogin']);
      allow update: if isAdmin();
    }

    // Ad Rules
    match /ads/{adId} {
      allow read: if (resource.data.status == 'approved') || isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn() && 
                      incoming().userId == request.auth.uid && 
                      incoming().status == 'pending' &&
                      incoming().createdAt == request.time;
      allow update: if (isOwner(existing().userId) && existing().status != 'approved' && 
                        incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'price', 'category', 'images', 'location', 'condition'])) || 
                      isAdmin();
      allow delete: if isOwner(existing().userId) || isAdmin();

      // List queries must be filtered
      allow list: if (resource.data.status == 'approved') || (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    // News/Articles Rules
    match /articles/{articleId} {
      allow read: if (resource.data.status == 'published') || isEditor();
      allow write: if isEditor();
      allow list: if (resource.data.status == 'published') || isEditor();
    }

    // Chat Rules
    match /chats/{chatId} {
      allow read, write: if isSignedIn() && (request.auth.uid in resource.data.participants);
      allow create: if isSignedIn() && (request.auth.uid in incoming().participants);
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);
      allow create: if isSignedIn() && 
                      (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants) && 
                      incoming().senderId == request.auth.uid && 
                      incoming().createdAt == request.time;
    }

    // Category Rules
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Settings Rules
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
